\frametitle{Ejemplo de inclusión de código}
\begin{lstlisting}[style=coursecode,language=R,caption={Regresion lineal simple en R}]
# Ejemplo en R: modelo de regresion lineal simple
datos <- data.frame(
  y = c(10, 12, 13, 15, 18),
  x = c(1, 2, 3, 4, 5)
)

ajuste <- lm(y ~ x, data = datos)
summary(ajuste)
\end{lstlisting}
